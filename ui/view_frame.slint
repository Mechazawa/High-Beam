// View-frame renderer. Shown when `current-view == VIEW-VIEWS`.
//
// Renders the flat block model the Rust side flattens out of the
// plugin's rendered ViewNode. Heading, Text, Spinner, ProgressBar,
// Button, and Input render with real visuals; other block kinds
// (textarea, image, row, divider) currently show as muted "[kind]"
// placeholders.

import { ScrollView, LineEdit } from "std-widgets.slint";
import { ViewBlock } from "types.slint";

export component ViewFrameView {
    in-out property <string> frame-title: "";
    in-out property <bool> has-title: false;
    in-out property <[ViewBlock]> blocks: [];

    in property <color> foreground-color;
    in property <color> muted-color;
    in property <color> border-color;
    in property <color> highlight-color;
    in property <length> font-size-title;
    in property <length> font-size-subtitle;
    in property <length> heading-font-size: 22px;

    // Tone palette — Stage 8 will pull these from the theme. For now
    // we synthesise reasonable defaults so the renderer paints
    // something readable against any theme.
    property <color> error-color: #d70015;
    property <color> success-color: #0c8430;
    property <color> warning-color: #b75f00;
    property <color> primary-button-bg: root.highlight-color;
    property <color> danger-button-bg: #d70015;
    property <color> default-button-bg: #00000010;

    width: 100%;
    height: 100%;

    // Esc inside a plugin view pops the top frame off the stack
    // instead of hiding the whole launcher. When the last frame goes
    // the host switches the window back to VIEW-QUERY.
    callback pop-view();
    // Fires when the user clicks a Button or activates a Row.
    // The Rust side resolves the callback id back to the originating
    // plugin/view and posts a `HostMessage::ViewEvent`.
    callback block-clicked(int);
    // Fires on every keystroke inside an Input/TextArea with an
    // onChange handler. Carries the new text so Rust can forward
    // it as the event's value.
    callback block-changed(int, string);
    // Fires when the user presses Enter inside an Input with an
    // onSubmit handler.
    callback block-submitted(int, string);

    forward-focus: focus-scope;

    focus-scope := FocusScope {
        key-pressed(event) => {
            if (event.text == Key.Escape) {
                root.pop-view();
                return accept;
            }
            return reject;
        }
    }

    VerticalLayout {
        padding: 10px;
        spacing: 4px;

        if root.has-title: Text {
            text: root.frame-title;
            font-size: root.heading-font-size;
            font-weight: 700;
            color: root.foreground-color;
        }

        if root.has-title: Rectangle {
            height: 1px;
            background: root.border-color;
        }

        ScrollView {
            VerticalLayout {
                spacing: 4px;

                for block in root.blocks: VerticalLayout {
                    if block.kind == "heading": Text {
                        text: block.text;
                        font-size: root.heading-font-size;
                        font-weight: 700;
                        color: root.foreground-color;
                    }
                    if block.kind == "text": Text {
                        text: block.text;
                        font-size:
                            block.size == "lg" ? root.font-size-title * 1.2
                            : block.size == "xl" ? root.font-size-title * 1.4
                            : block.size == "sm" ? root.font-size-subtitle
                            : root.font-size-title;
                        color:
                            block.tone == "muted" ? root.muted-color
                            : block.tone == "error" ? root.error-color
                            : block.tone == "success" ? root.success-color
                            : block.tone == "warning" ? root.warning-color
                            : root.foreground-color;
                        wrap: word-wrap;
                    }
                    if block.kind == "spinner": HorizontalLayout {
                        spacing: 8px;
                        Rectangle {
                            width: 10px;
                            height: 10px;
                            border-radius: 5px;
                            background: root.muted-color;
                            opacity: 0.6;
                        }
                        if block.has-label: Text {
                            text: block.label;
                            color: root.muted-color;
                            font-size: root.font-size-subtitle;
                        }
                    }
                    if block.kind == "progress": VerticalLayout {
                        spacing: 2px;
                        if block.has-label: Text {
                            text: block.label;
                            color: root.muted-color;
                            font-size: root.font-size-subtitle;
                        }
                        Rectangle {
                            height: 5px;
                            border-radius: 2.5px;
                            background: root.border-color;
                            Rectangle {
                                x: 0;
                                y: 0;
                                height: parent.height;
                                width:
                                    block.has-progress-value
                                        ? parent.width * max(0, min(1, block.progress-value))
                                        : parent.width * 0.3;
                                border-radius: 2.5px;
                                background: root.foreground-color;
                            }
                        }
                    }
                    if block.kind == "button": Rectangle {
                        // Pad the touch surface so a 14-line view feels
                        // tappable; click feedback comes from the
                        // TouchArea below changing background opacity.
                        height: 28px;
                        border-radius: 4px;
                        background:
                            block.tone == "primary" ? root.primary-button-bg
                            : block.tone == "danger" ? root.danger-button-bg
                            : root.default-button-bg;
                        opacity: button-touch.pressed ? 0.7 : 1.0;

                        Text {
                            text: block.text;
                            font-size: root.font-size-subtitle;
                            color:
                                (block.tone == "primary" || block.tone == "danger")
                                    ? #ffffff
                                    : root.foreground-color;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }

                        button-touch := TouchArea {
                            mouse-cursor: pointer;
                            clicked => {
                                if (block.has-on-click) {
                                    root.block-clicked(block.on-click-id);
                                }
                            }
                        }
                    }
                    if block.kind == "input": HorizontalLayout {
                        // Slint's LineEdit owns its internal text state;
                        // we seed it from `block.value` and notify Rust
                        // on every edited(string) emission. The
                        // controlled-cursor concern (Stage 4c
                        // commitment) is handled by NOT mirroring
                        // `block.value` back into `input.text` on
                        // every re-render — only the first paint and
                        // explicit value resets.
                        input-edit := LineEdit {
                            text: block.value;
                            placeholder-text: block.label;
                            font-size: root.font-size-subtitle;
                            edited(text) => {
                                if (block.has-on-change) {
                                    root.block-changed(block.on-change-id, text);
                                }
                            }
                            accepted(text) => {
                                if (block.has-on-submit) {
                                    root.block-submitted(block.on-submit-id, text);
                                }
                            }
                        }
                    }
                    // Fallback for not-yet-rendered block kinds.
                    if block.kind != "heading"
                        && block.kind != "text"
                        && block.kind != "spinner"
                        && block.kind != "progress"
                        && block.kind != "button"
                        && block.kind != "input": Text {
                        text: "[" + block.kind + "]";
                        color: root.muted-color;
                        font-size: root.font-size-subtitle;
                        font-italic: true;
                    }
                }
            }
        }
    }
}
