// Shared struct definitions used by all view components.
// Import this file from every .slint file that needs these types.

// Wire shape sent across Rust -> Slint for each row. `key` is the composite
// `<plugin>:<result_key>` so two plugins emitting the same `key` string don't
// collide. Slint structs need fixed types, so "no icon" is encoded as the
// empty image (`has-icon = false`), and the row paints a muted placeholder
// square in that case to keep title columns aligned.
export struct ResultRow {
    key: string,
    title: string,
    subtitle: string,    // empty string when absent — Slint structs need fixed types
    has-subtitle: bool,
    icon: image,
    has-icon: bool,
    // Plugin-supplied overrides shown while the alt-action modifier is
    // held. Empty `alt-*` strings + `has-alt-* = false` mean "no
    // override" — the row keeps its primary labels.
    alt-title: string,
    has-alt-title: bool,
    alt-subtitle: string,
    has-alt-subtitle: bool,
}

// One plugin slot in the settings sidebar.
export struct PluginSlot {
    name: string,
    display-name: string,    // falls back to `name` when empty
    enabled: bool,
}

// One capability row in the install-confirmation view.
// `is-new` is true only during an update that introduces the cap.
export struct ConfirmCapRow {
    cap: string,
    explanation: string,
    is-new: bool,
}

// One block in a flattened view tree. The Rust side walks the
// rendered ViewNode and emits one entry per leaf block (Stack
// containers contribute their children inline for v0). `kind` is
// one of:
//   "heading" | "text" | "spinner" | "progress" | "button" | "input"
// Anything outside that set renders as a muted "[kind]" placeholder.
export struct ViewBlock {
    kind: string,
    // Heading / Text payload — also doubles as the Button label.
    text: string,
    // Text tone OR button tone:
    //   text:    "" | "muted" | "error" | "success" | "warning"
    //   button:  "" | "default" | "primary" | "danger"
    tone: string,
    // Text size: "" | "sm" | "md" | "lg" | "xl".
    size: string,
    // Progress bar: 0..1; indeterminate sentinel < 0.
    progress-value: float,
    // Spinner / ProgressBar label OR Input placeholder.
    label: string,
    // Input controlled value (and current text seed).
    value: string,
    // Stable id on interactive blocks. "" when the block doesn't
    // accept user input.
    id: string,
    // Callback ids substituted in by the SDK render walker. 0 means
    // "no handler" — Slint branches on the field's truthiness via
    // the `has-*` flags below to keep semantics explicit.
    on-click-id: int,
    on-change-id: int,
    on-submit-id: int,
    // Has-flags so Slint can branch without ambiguous empty-string
    // comparisons.
    has-text: bool,
    has-label: bool,
    has-value: bool,
    has-progress-value: bool,
    has-on-click: bool,
    has-on-change: bool,
    has-on-submit: bool,
}

// One option input in the settings detail pane. Option `kind` is one of:
//   "string" | "bool" | "int" | "enum"
// `value-*` columns are all populated; the matching one for `kind` is the
// truth. `choices` is a CSV of enum choices (Slint structs can't carry
// `[string]` directly without naming a model type).
export struct PluginOption {
    plugin-name: string,
    key: string,
    label: string,
    kind: string,
    value-string: string,
    value-bool: bool,
    value-int: int,
    int-min: int,
    int-max: int,
    has-int-min: bool,
    has-int-max: bool,
    enum-choices: string,
}
