// Stage 2 placeholder query window. Stage 3 replaces the single TextInput with
// the real input + result rows layout. Tokens here are hard-coded; theming
// (Stage 8) will bind them to runtime properties from theme.toml.

export component QueryWindow inherits Window {
    title: "High Beam";
    no-frame: true;
    always-on-top: true;
    background: transparent;
    default-font-size: 18px;

    in-out property <string> query-text;
    callback query-edited(string);
    callback escape-pressed();

    // forward-focus makes the input the focus target whenever the window
    // itself is focused. Combined with the explicit `input.focus()` call in
    // `focus-input()` (invoked from Rust after each show), this ensures the
    // caret is live the moment the window appears, without needing a click.
    forward-focus: input;

    public function focus-input() {
        input.focus();
    }

    width: 760px;
    height: 80px;

    // Translucent rounded panel sits inside a transparent window so the corner
    // radius reads cleanly on the desktop.
    Rectangle {
        background: #ffffffea;
        border-radius: 14px;
        border-width: 1px;
        border-color: #00000010;

        input := TextInput {
            // Span the full panel so `vertical-alignment: center` has room to
            // act on. Without an explicit height, the TextInput sizes to its
            // glyph metrics and the alignment property has nothing to align
            // against — which is what produced the top-aligned text bug.
            x: 20px;
            y: 0;
            width: parent.width - 40px;
            height: parent.height;
            font-size: 32px;
            color: #1d1d1f;
            single-line: true;
            vertical-alignment: center;
            text: root.query-text;
            // Placeholder text rendered behind the input when empty.
            // TextInput has no native placeholder; emulate with a sibling Text.

            edited => {
                root.query-text = self.text;
                root.query-edited(self.text);
            }

            key-pressed(event) => {
                if (event.text == Key.Escape) {
                    root.escape-pressed();
                    return accept;
                }
                reject
            }
        }

        // Faux placeholder: only visible when the input is empty. Mirrors the
        // input's geometry and alignment so the two sit at the same baseline.
        Text {
            x: 20px;
            y: 0;
            width: parent.width - 40px;
            height: parent.height;
            text: "Query…";
            font-size: 32px;
            color: #86868b;
            vertical-alignment: center;
            visible: root.query-text == "";
        }
    }
}
