// Query input + result rows + settings view. The single source of truth for
// what's displayed sits on the Rust side; Slint-side state is just
// `query-text`, `results`, `selected-index`, and `current-view`.
//
// The window switches between two views: the launcher (`current-view ==
// VIEW-QUERY`) and the settings screen (`current-view == VIEW-SETTINGS`).
// Cmd+, opens settings from the launcher; Esc returns to the launcher (or
// hides if already on the launcher).
//
// Colors and dimensions exposed as `in-out` tokens at the top of `QueryWindow`.
// Defaults match the bundled yosemite-spotlight theme so a theme-free run is
// visually identical to the pre-theming build. Layout-load-bearing constants
// (row height, icon size, input padding) remain inline — theming layout is
// out of scope for v1.

import { ScrollView } from "std-widgets.slint";

// Wire shape sent across Rust -> Slint for each row. `key` is the composite
// `<plugin>:<result_key>` so two plugins emitting the same `key` string don't
// collide. Slint structs need fixed types, so "no icon" is encoded as the
// empty image (`has-icon = false`), and the row paints a muted placeholder
// square in that case to keep title columns aligned.
export struct ResultRow {
    key: string,
    title: string,
    subtitle: string,    // empty string when absent — Slint structs need fixed types
    has-subtitle: bool,
    icon: image,
    has-icon: bool,
}

// One plugin slot in the settings sidebar.
export struct PluginSlot {
    name: string,
    display-name: string,    // falls back to `name` when empty
    enabled: bool,
}

// One capability row in the install-confirmation view.
// `is-new` is true only during an update that introduces the cap.
export struct ConfirmCapRow {
    cap: string,
    explanation: string,
    is-new: bool,
}

// One option input in the settings detail pane. Option `kind` is one of:
//   "string" | "bool" | "int" | "enum"
// `value-*` columns are all populated; the matching one for `kind` is the
// truth. `choices` is a CSV of enum choices (Slint structs can't carry
// `[string]` directly without naming a model type).
export struct PluginOption {
    plugin-name: string,
    key: string,
    label: string,
    kind: string,
    value-string: string,
    value-bool: bool,
    value-int: int,
    int-min: int,
    int-max: int,
    has-int-min: bool,
    has-int-max: bool,
    enum-choices: string,
}

export component QueryWindow inherits Window {
    title: "High Beam";
    no-frame: true;
    always-on-top: true;
    background: transparent;
    default-font-size: 18px;
    default-font-family: root.font-family;

    in-out property <string> query-text;
    in-out property <[ResultRow]> results: [];
    in-out property <int> selected-index: 0;
    in-out property <int> max-rows: 9;

    // View state. 0 = launcher (query), 1 = settings, 2 = install confirm.
    property <int> VIEW-QUERY: 0;
    property <int> VIEW-SETTINGS: 1;
    property <int> VIEW-CONFIRM: 2;
    in-out property <int> current-view: 0;

    // Settings view state.
    in-out property <[PluginSlot]> plugin-slots: [];
    in-out property <int> selected-plugin-index: 0;
    in-out property <[PluginOption]> plugin-options: [];
    // Metadata for the selected plugin — populated by Rust in refresh-options.
    // Empty strings mean the field is absent; the pane hides those rows.
    in-out property <string> selected-plugin-version: "";
    in-out property <string> selected-plugin-description: "";
    // True when the "Global" rail entry is selected — the right pane then
    // shows the app-wide settings instead of plugin options. Defaulted to
    // true so opening settings lands on Global rather than a random plugin.
    in-out property <bool> showing-global: true;
    in-out property <string> hotkey-value: "Shift+Space";
    // Keyboard rail selection: 0 = Global, 1 = plugin[0], 2 = plugin[1], etc.
    // Distinct from `selected-plugin-index` so arrow-key nav can sit on Global
    // without mutating the plugin selection state behind it.
    in-out property <int> rail-focus-index: 0;

    // Install-confirmation view state. Populated by Rust before switching to
    // VIEW-CONFIRM; cleared on install or cancel.
    in-out property <string> confirm-plugin-name: "";
    in-out property <string> confirm-display-name: "";
    in-out property <string> confirm-version: "";
    in-out property <string> confirm-description: "";
    in-out property <string> confirm-manifest-url: "";
    in-out property <[ConfirmCapRow]> confirm-capabilities: [];
    // 0 = Install button focused, 1 = Cancel button focused.
    in-out property <int> confirm-focus-index: 0;

    // Fires when the user clicks Install or presses Enter on the Install button.
    callback confirm-install();
    // Fires when the user clicks Cancel or presses Escape.
    callback confirm-cancel();

    // Theme tokens. Defaults reproduce the bundled yosemite-spotlight theme so
    // a missing theme.toml is byte-identical to the pre-theming build.
    in-out property <color> background-color: #ffffffea;
    in-out property <color> foreground-color: #1d1d1f;
    in-out property <color> muted-color: #86868b;
    // `highlight` is part of the documented token surface but not yet bound in
    // markup — kept so user themes can set it without parse errors.
    in-out property <color> highlight-color: #0a84ff;
    in-out property <color> selection-color: #0a84ff33;
    in-out property <color> border-color: #00000010;
    in-out property <string> font-family: "";
    in-out property <length> font-size-query: 32px;
    in-out property <length> font-size-title: 14px;
    in-out property <length> font-size-subtitle: 12px;
    in-out property <length> window-width: 760px;
    in-out property <length> window-border-radius: 14px;

    callback query-edited(string);
    callback escape-pressed();
    // Fires from Rust just before the window hides — Esc, focus loss,
    // action-induced hide all go through it. Carries the current input text
    // so app.rs can decide whether to persist it to query history.
    callback persist-dismiss(string);
    // Fires when the user presses Enter on the highlighted row. The Rust side
    // looks up the corresponding result and runs its action.
    callback invoke-selected();
    // History cycling — Up only acts on history when the input is empty (so
    // regular Up keeps navigating results once the user has typed). Down only
    // acts on history while previewing. Rust owns the state machine and
    // writes the cycled text back via `set_query_text` + `set-input-text`.
    callback history-up();
    callback history-down();
    // Whether the input currently shows a history preview (cycled, not yet
    // committed). The input is rendered with the muted text colour while
    // this is true; the first edit or Enter commits and flips this back.
    in-out property <bool> is-history-preview: false;

    // Settings-related callbacks. Rust persists state, then pushes the
    // re-rendered slots/options back through the `in-out` properties.
    callback open-settings();
    callback close-settings();
    callback select-plugin(int);
    callback toggle-plugin(string, bool);
    callback set-option-string(string, string, string);
    callback set-option-bool(string, string, bool);
    callback set-option-int(string, string, int);
    // Global-pane callbacks. `set-hotkey` fires on blur/commit of the hotkey
    // input; `select-global` flips the rail selection to the global entry.
    callback set-hotkey(string);
    callback select-global();
    // Drag/position callbacks. Slint's frameless-window drag isn't built-in,
    // so we hand off to winit's `drag_window()` on the Rust side. The
    // launcher background fires `request-window-drag` on left-button-down;
    // the OS owns the move loop from that point.
    callback request-window-drag();
    // Settings → Global → "Recenter window" — clears any saved position and
    // re-centers the currently visible window. No-op if nothing was saved.
    callback recenter-window();
    // Settings → Global → "Open config directory" — opens the platform
    // config dir in Finder / xdg-open. The directory holds settings.toml,
    // theme.toml, and the per-plugin user-edited files.
    callback open-config-dir();

    // forward-focus makes the input the focus target whenever the window
    // itself is focused. Combined with the explicit `input.focus()` call in
    // `focus-input()` (invoked from Rust after each show), this ensures the
    // caret is live the moment the window appears, without needing a click.
    forward-focus: input;

    public function focus-input() {
        input.focus();
    }

    // Reset the input's own `text` directly. The binding `text: root.query-text`
    // is one-way and gets severed the moment the TextInput writes to its own
    // `text` (which happens on every keystroke via the `edited` callback). After
    // that, mutating `query-text` from Rust no longer propagates back into the
    // input. Assigning `input.text` here side-steps the broken binding so the
    // displayed content actually clears.
    public function clear-input() {
        input.text = "";
        root.query-text = "";
        root.results = [];
        root.selected-index = 0;
    }

    // Replace the visible input text with `text` without firing
    // `query-edited`. The history-cycle path dispatches the plugin query
    // directly so it can keep the cycle cursor alive; if we re-entered via
    // `query-edited` the edit-while-cycling state machine would clobber it.
    public function set-input-text(text: string) {
        input.text = text;
        root.query-text = text;
    }

    // Switch between launcher and settings views. Public so Rust can invoke
    // (from the Core `settings` verb action).
    public function show-settings() {
        root.current-view = root.VIEW-SETTINGS;
        root.open-settings();
        // Land focus on the rail FocusScope so arrow-key nav is live the
        // moment the settings view appears.
        rail-focus.focus();
    }
    public function show-query() {
        root.current-view = root.VIEW-QUERY;
        input.focus();
    }

    // Switch to the install-confirmation view.  Rust populates the
    // `confirm-*` properties before calling this.
    public function show-confirm() {
        root.current-view = root.VIEW-CONFIRM;
        root.confirm-focus-index = 0;
        confirm-focus.focus();
    }

    // Apply `rail-focus-index` to the visual selection + fire the matching
    // controller callback. Centralised so arrow keys, clicks, and any future
    // jump-to-entry all produce the same observable state change.
    public function sync-rail-selection() {
        if (root.rail-focus-index <= 0) {
            root.showing-global = true;
            root.select-global();
        } else {
            root.showing-global = false;
            root.selected-plugin-index = root.rail-focus-index - 1;
            root.select-plugin(root.selected-plugin-index);
        }
    }

    // Derived: how tall the rows area should be. Each row is ~52px (padding
    // included). 9 rows max keeps the window from swallowing the whole screen.
    property <int> visible-row-count: min(results.length, max-rows);
    property <length> rows-height: visible-row-count * 56px;
    property <length> input-height: 80px;
    // Settings view geometry: wider + taller than the launcher so the plugin
    // list and option inputs both have breathing room.
    property <length> settings-height: 480px;

    width: root.window-width;
    height: root.current-view == root.VIEW-SETTINGS
        ? settings-height
        : root.current-view == root.VIEW-CONFIRM
            ? settings-height
            : input-height + (results.length > 0 ? rows-height + 1px : 0);

    // Translucent rounded panel sits inside a transparent window so the corner
    // radius reads cleanly on the desktop.
    Rectangle {
        background: root.background-color;
        border-radius: root.window-border-radius;
        border-width: 1px;
        border-color: root.border-color;

        // Whole-panel drag handle. Mounted first so it sits at the bottom of
        // the z-stack — child TouchAreas (result rows, settings rail, etc.)
        // and the TextInput steal clicks on themselves; the dead space
        // (input gutter, padding, area between widgets) falls through here
        // and starts a native window drag. Mouse cursor stays default so
        // the field still reads as text-editable.
        TouchArea {
            mouse-cursor: default;
            pointer-event(event) => {
                if (event.kind == PointerEventKind.down && event.button == PointerEventButton.left) {
                    root.request-window-drag();
                }
            }
        }

        // ---- Launcher view ----
        // Visible-toggle (rather than `if`) keeps the `input` id in scope for
        // `focus-input()` / `clear-input()` regardless of which view is up,
        // which Slint requires because element ids only exist when the
        // element itself is instantiated.
        launcher-view := VerticalLayout {
            visible: root.current-view == root.VIEW-QUERY;
            // Input area
            Rectangle {
                height: input-height;
                input := TextInput {
                    // Span the input area so vertical-alignment has room to
                    // act on. Without an explicit height, the TextInput sizes
                    // to its glyph metrics and the alignment property has
                    // nothing to align against.
                    x: 20px;
                    y: 0;
                    width: parent.width - 40px;
                    height: parent.height;
                    font-size: root.font-size-query;
                    color: root.is-history-preview ? root.muted-color : root.foreground-color;
                    single-line: true;
                    vertical-alignment: center;
                    text: root.query-text;

                    edited => {
                        root.query-text = self.text;
                        root.query-edited(self.text);
                    }

                    key-pressed(event) => {
                        // Cmd+, (macOS) / Ctrl+, (Linux) opens the settings
                        // view. Slint's event.modifiers struct surfaces both
                        // — checking either lets the same binding work on
                        // both platforms without #[cfg].
                        if (event.text == "," && (event.modifiers.meta || event.modifiers.control)) {
                            root.show-settings();
                            return accept;
                        }
                        if (event.text == Key.Escape) {
                            root.escape-pressed();
                            return accept;
                        }
                        // Up cycles history when input is empty or already
                        // previewing; otherwise it moves the selection up
                        // the result list.
                        if (event.text == Key.UpArrow) {
                            if (self.text == "" || root.is-history-preview) {
                                root.history-up();
                                return accept;
                            }
                            if (root.selected-index > 0) {
                                root.selected-index -= 1;
                            }
                            return accept;
                        }
                        // Down walks newer through history while previewing;
                        // otherwise navigates results.
                        if (event.text == Key.DownArrow) {
                            if (root.is-history-preview) {
                                root.history-down();
                                return accept;
                            }
                            if (root.selected-index < root.results.length - 1) {
                                root.selected-index += 1;
                            }
                            return accept;
                        }
                        if (event.text == Key.Return) {
                            // While previewing, Enter commits the preview as
                            // the live query (the Rust side fires the plugin
                            // pipeline). Otherwise: invoke the selected row.
                            if (root.is-history-preview) {
                                root.query-edited(self.text);
                                return accept;
                            }
                            if (root.results.length > 0) {
                                root.invoke-selected();
                            }
                            return accept;
                        }
                        reject
                    }
                }

                // Faux placeholder: only visible when the input is empty.
                Text {
                    x: 20px;
                    y: 0;
                    width: parent.width - 40px;
                    height: parent.height;
                    text: "Query…";
                    font-size: root.font-size-query;
                    color: root.muted-color;
                    vertical-alignment: center;
                    visible: root.query-text == "";
                }
            }

            // Separator line — only visible when there are results.
            Rectangle {
                height: results.length > 0 ? 1px : 0;
                background: root.border-color;
            }

            // Result rows
            Rectangle {
                height: rows-height;
                clip: true;
                visible: results.length > 0;

                VerticalLayout {
                    spacing: 0px;
                    for row[idx] in results: TouchArea {
                        height: 56px;
                        clicked => {
                            root.selected-index = idx;
                            root.invoke-selected();
                        }
                        Rectangle {
                            background: idx == root.selected-index ? root.selection-color : transparent;
                            HorizontalLayout {
                                padding-left: 20px;
                                padding-right: 20px;
                                padding-top: 8px;
                                padding-bottom: 8px;
                                spacing: 12px;
                                alignment: start;

                                // Icon slot — fixed 36x36 regardless of whether the row has an
                                // icon, so the title column lines up across rows. Image always
                                // paints (defaults to a transparent empty image); the muted
                                // outline behind it is what reads as "no icon" when present.
                                Rectangle {
                                    width: 36px;
                                    height: 36px;
                                    y: (parent.height - self.height) / 2;
                                    border-radius: 4px;
                                    border-width: row.has-icon ? 0px : 1px;
                                    border-color: root.muted-color.with-alpha(0.25);
                                    Image {
                                        x: 0; y: 0;
                                        width: parent.width;
                                        height: parent.height;
                                        source: row.icon;
                                        image-fit: contain;
                                    }
                                }

                                VerticalLayout {
                                    spacing: 2px;
                                    alignment: center;
                                    Text {
                                        text: row.title;
                                        color: root.foreground-color;
                                        font-size: root.font-size-title;
                                        overflow: elide;
                                    }

                                    if row.has-subtitle: Text {
                                        text: row.subtitle;
                                        color: root.muted-color;
                                        font-size: root.font-size-subtitle;
                                        overflow: elide;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        // ---- Settings view ----
        settings-view := VerticalLayout {
            visible: root.current-view == root.VIEW-SETTINGS;
            // Header bar.
            Rectangle {
                height: 48px;
                background: transparent;
                HorizontalLayout {
                    padding-left: 20px;
                    padding-right: 20px;
                    padding-top: 12px;
                    padding-bottom: 12px;
                    spacing: 12px;
                    alignment: space-between;

                    Text {
                        text: "Settings";
                        color: root.foreground-color;
                        font-size: 18px;
                        vertical-alignment: center;
                    }

                    // FocusScope so Tab traversal can land on Done; Enter/
                    // Space activates the same way clicking does. Mouse path
                    // is preserved via the inner TouchArea.
                    done-focus := FocusScope {
                        width: 80px;
                        height: 24px;
                        key-pressed(event) => {
                            if (event.text == Key.Return || event.text == " ") {
                                root.close-settings();
                                root.show-query();
                                return accept;
                            }
                            if (event.text == Key.Escape) {
                                root.close-settings();
                                root.show-query();
                                return accept;
                            }
                            reject
                        }
                        TouchArea {
                            clicked => { root.close-settings(); root.show-query(); }
                            Rectangle {
                                background: root.selection-color;
                                border-radius: 6px;
                                border-width: done-focus.has-focus ? 1px : 0px;
                                border-color: root.foreground-color;
                                Text {
                                    text: "Done (Esc)";
                                    color: root.foreground-color;
                                    font-size: root.font-size-subtitle;
                                    vertical-alignment: center;
                                    horizontal-alignment: center;
                                }
                            }
                        }
                    }
                }
            }

            Rectangle {
                height: 1px;
                background: root.border-color;
            }

            // Body: split into left rail (plugin list) + right pane (options).
            HorizontalLayout {
                spacing: 0px;

                // Left rail — "Global" entry followed by the plugin list.
                // Wrapped in a FocusScope so arrow keys + Space/Enter drive
                // rail navigation when the focus lands here; Tab forwards
                // into the right pane via the FocusScope's default chain.
                Rectangle {
                    width: 260px;
                    background: transparent;
                    border-color: root.border-color;
                    rail-focus := FocusScope {
                        key-pressed(event) => {
                            if (event.text == Key.UpArrow) {
                                if (root.rail-focus-index > 0) {
                                    root.rail-focus-index -= 1;
                                    root.sync-rail-selection();
                                }
                                return accept;
                            }
                            if (event.text == Key.DownArrow) {
                                if (root.rail-focus-index < root.plugin-slots.length) {
                                    root.rail-focus-index += 1;
                                    root.sync-rail-selection();
                                }
                                return accept;
                            }
                            if (event.text == " " || event.text == Key.Return) {
                                // Space/Enter on a plugin row flips its
                                // toggle. The Global row has no toggle, so
                                // it's an explicit no-op there.
                                if (root.rail-focus-index >= 1
                                    && root.rail-focus-index - 1 < root.plugin-slots.length) {
                                    root.toggle-plugin(
                                        root.plugin-slots[root.rail-focus-index - 1].name,
                                        !root.plugin-slots[root.rail-focus-index - 1].enabled
                                    );
                                }
                                return accept;
                            }
                            if (event.text == Key.Escape) {
                                root.close-settings();
                                root.show-query();
                                return accept;
                            }
                            reject
                        }
                        ScrollView {
                            VerticalLayout {
                                spacing: 0px;
                                // "Global" entry pinned at the top of the rail.
                                TouchArea {
                                    height: 44px;
                                    clicked => {
                                        root.rail-focus-index = 0;
                                        root.sync-rail-selection();
                                        rail-focus.focus();
                                    }
                                    Rectangle {
                                        background: root.showing-global ? root.selection-color : transparent;
                                        HorizontalLayout {
                                            padding-left: 16px;
                                            padding-right: 12px;
                                            padding-top: 6px;
                                            padding-bottom: 6px;
                                            spacing: 8px;
                                            alignment: start;
                                            VerticalLayout {
                                                alignment: center;
                                                Text {
                                                    text: "Global";
                                                    color: root.foreground-color;
                                                    font-size: root.font-size-title;
                                                    overflow: elide;
                                                }
                                            }
                                        }
                                    }
                                }
                                // Faint separator between Global and the plugin list.
                                Rectangle {
                                    height: 1px;
                                    background: root.border-color;
                                }
                                for slot[i] in plugin-slots: TouchArea {
                                    height: 44px;
                                    clicked => {
                                        root.rail-focus-index = i + 1;
                                        root.sync-rail-selection();
                                        rail-focus.focus();
                                    }
                                    Rectangle {
                                        background: !root.showing-global && i == root.selected-plugin-index ? root.selection-color : transparent;
                                        HorizontalLayout {
                                            padding-left: 16px;
                                            padding-right: 12px;
                                            padding-top: 6px;
                                            padding-bottom: 6px;
                                            spacing: 8px;
                                            alignment: space-between;
                                            VerticalLayout {
                                                alignment: center;
                                                Text {
                                                    text: slot.display-name == "" ? slot.name : slot.display-name;
                                                    color: root.foreground-color;
                                                    font-size: root.font-size-title;
                                                    overflow: elide;
                                                }
                                            }
                                            // Tiny enable/disable toggle: just a checkbox-style square.
                                            TouchArea {
                                                width: 44px;
                                                height: 22px;
                                                clicked => {
                                                    root.toggle-plugin(slot.name, !slot.enabled);
                                                }
                                                Rectangle {
                                                    background: slot.enabled ? root.highlight-color : root.muted-color.with-alpha(0.3);
                                                    border-radius: 11px;
                                                    Rectangle {
                                                        x: slot.enabled ? parent.width - self.width - 2px : 2px;
                                                        y: (parent.height - self.height) / 2;
                                                        width: 18px;
                                                        height: 18px;
                                                        background: white;
                                                        border-radius: 9px;
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                // Vertical divider.
                Rectangle {
                    width: 1px;
                    background: root.border-color;
                }

                // Right pane — either global settings or options for the
                // selected plugin, depending on the rail selection.
                Rectangle {
                    background: transparent;
                    // Global pane: hotkey input + restart-to-apply caption.
                    // Hot-reload of the hotkey is out of scope for v1, so the
                    // caption is the contract with the user.
                    if root.showing-global: ScrollView {
                        VerticalLayout {
                            padding: 16px;
                            spacing: 12px;

                            Text {
                                text: "Global";
                                color: root.foreground-color;
                                font-size: 16px;
                            }

                            VerticalLayout {
                                spacing: 4px;
                                Text {
                                    text: "Hotkey";
                                    color: root.foreground-color;
                                    font-size: root.font-size-title;
                                }
                                Rectangle {
                                    height: 28px;
                                    background: root.muted-color.with-alpha(0.08);
                                    border-radius: 4px;
                                    border-width: 1px;
                                    border-color: root.border-color;
                                    hotkey-input := TextInput {
                                        x: 8px;
                                        y: 0;
                                        width: parent.width - 16px;
                                        height: parent.height;
                                        font-size: root.font-size-title;
                                        color: root.foreground-color;
                                        single-line: true;
                                        vertical-alignment: center;
                                        text: root.hotkey-value;
                                        // Commit on edit so the value persists without a
                                        // blur/enter dance; the daemon snapshots at startup.
                                        edited => {
                                            root.set-hotkey(self.text);
                                        }
                                        // Enter commits-and-blurs by returning focus to
                                        // the rail; the rail FocusScope is the natural
                                        // "home" for keyboard nav in the settings view.
                                        accepted => {
                                            root.set-hotkey(self.text);
                                            rail-focus.focus();
                                        }
                                        // Escape from a TextInput won't bubble to a
                                        // parent FocusScope, so handle it here directly.
                                        key-pressed(event) => {
                                            if (event.text == Key.Escape) {
                                                root.close-settings();
                                                root.show-query();
                                                return accept;
                                            }
                                            reject
                                        }
                                    }
                                }
                                Text {
                                    text: "Restart to apply.";
                                    color: root.muted-color;
                                    font-size: root.font-size-subtitle;
                                }
                            }

                            // Window position group — only meaningful if the
                            // user has dragged the launcher. We always show
                            // the button (cheaper than a property round-trip
                            // for the saved-or-not flag); clearing when
                            // already-default is a no-op on disk.
                            VerticalLayout {
                                spacing: 4px;
                                Text {
                                    text: "Window position";
                                    color: root.foreground-color;
                                    font-size: root.font-size-title;
                                }
                                TouchArea {
                                    width: 140px;
                                    height: 28px;
                                    clicked => {
                                        root.recenter-window();
                                    }
                                    Rectangle {
                                        background: root.selection-color;
                                        border-radius: 4px;
                                        Text {
                                            text: "Recenter window";
                                            color: root.foreground-color;
                                            font-size: root.font-size-subtitle;
                                            vertical-alignment: center;
                                            horizontal-alignment: center;
                                        }
                                    }
                                }
                                Text {
                                    text: "Forgets the saved drag position and re-centers the launcher. To do this manually, delete [global.launcher_position] from settings.toml.";
                                    color: root.muted-color;
                                    font-size: root.font-size-subtitle;
                                    wrap: word-wrap;
                                }
                            }

                            // Config files group — surfaces the on-disk
                            // location for users who want to hand-edit
                            // settings.toml / theme.toml / plugin data.
                            VerticalLayout {
                                spacing: 4px;
                                Text {
                                    text: "Config files";
                                    color: root.foreground-color;
                                    font-size: root.font-size-title;
                                }
                                TouchArea {
                                    width: 180px;
                                    height: 28px;
                                    clicked => {
                                        root.open-config-dir();
                                    }
                                    Rectangle {
                                        background: root.selection-color;
                                        border-radius: 4px;
                                        Text {
                                            text: "Open config directory";
                                            color: root.foreground-color;
                                            font-size: root.font-size-subtitle;
                                            vertical-alignment: center;
                                            horizontal-alignment: center;
                                        }
                                    }
                                }
                                Text {
                                    text: "Opens the platform config dir in Finder. Holds settings.toml, theme.toml, and per-plugin overrides.";
                                    color: root.muted-color;
                                    font-size: root.font-size-subtitle;
                                    wrap: word-wrap;
                                }
                            }
                        }
                    }

                    // Plugin-options pane.
                    if !root.showing-global: ScrollView {
                        VerticalLayout {
                            padding: 16px;
                            spacing: 12px;
                            // Selected-plugin header: name + optional version.
                            if plugin-slots.length > 0 && root.selected-plugin-index < plugin-slots.length: HorizontalLayout {
                                spacing: 8px;
                                alignment: space-between;
                                Text {
                                    text: plugin-slots[root.selected-plugin-index].display-name == ""
                                        ? plugin-slots[root.selected-plugin-index].name
                                        : plugin-slots[root.selected-plugin-index].display-name;
                                    color: root.foreground-color;
                                    font-size: root.font-size-title;
                                    vertical-alignment: center;
                                }
                                if root.selected-plugin-version != "": Text {
                                    text: root.selected-plugin-version;
                                    color: root.muted-color;
                                    font-size: root.font-size-subtitle;
                                    vertical-alignment: center;
                                }
                            }

                            // Plugin description — only shown when present.
                            if root.selected-plugin-description != "": Text {
                                text: root.selected-plugin-description;
                                color: root.muted-color;
                                font-size: root.font-size-subtitle;
                                wrap: word-wrap;
                            }

                            if plugin-options.length == 0: Text {
                                text: "This plugin has no configurable options.";
                                color: root.muted-color;
                                font-size: root.font-size-subtitle;
                            }

                            for opt in plugin-options: Rectangle {
                                height: 56px;
                                background: transparent;
                                VerticalLayout {
                                    spacing: 4px;
                                    Text {
                                        text: opt.label;
                                        color: root.foreground-color;
                                        font-size: root.font-size-title;
                                    }

                                    if opt.kind == "string": Rectangle {
                                        height: 28px;
                                        background: root.muted-color.with-alpha(0.08);
                                        border-radius: 4px;
                                        border-width: 1px;
                                        border-color: root.border-color;
                                        opt-string-input := TextInput {
                                            x: 8px;
                                            y: 0;
                                            width: parent.width - 16px;
                                            height: parent.height;
                                            font-size: root.font-size-title;
                                            color: root.foreground-color;
                                            single-line: true;
                                            vertical-alignment: center;
                                            text: opt.value-string;
                                            edited => {
                                                root.set-option-string(opt.plugin-name, opt.key, self.text);
                                            }
                                            // Enter commit-and-blurs — same convention as the
                                            // hotkey input. Escape bails out of settings.
                                            accepted => {
                                                root.set-option-string(opt.plugin-name, opt.key, self.text);
                                                rail-focus.focus();
                                            }
                                            key-pressed(event) => {
                                                if (event.text == Key.Escape) {
                                                    root.close-settings();
                                                    root.show-query();
                                                    return accept;
                                                }
                                                reject
                                            }
                                        }
                                    }

                                    if opt.kind == "bool": TouchArea {
                                        width: 44px;
                                        height: 22px;
                                        clicked => {
                                            root.set-option-bool(opt.plugin-name, opt.key, !opt.value-bool);
                                        }
                                        Rectangle {
                                            background: opt.value-bool ? root.highlight-color : root.muted-color.with-alpha(0.3);
                                            border-radius: 11px;
                                            Rectangle {
                                                x: opt.value-bool ? parent.width - self.width - 2px : 2px;
                                                y: (parent.height - self.height) / 2;
                                                width: 18px;
                                                height: 18px;
                                                background: white;
                                                border-radius: 9px;
                                            }
                                        }
                                    }

                                    if opt.kind == "int": Rectangle {
                                        height: 28px;
                                        background: root.muted-color.with-alpha(0.08);
                                        border-radius: 4px;
                                        border-width: 1px;
                                        border-color: root.border-color;
                                        opt-int-input := TextInput {
                                            x: 8px;
                                            y: 0;
                                            width: parent.width - 16px;
                                            height: parent.height;
                                            font-size: root.font-size-title;
                                            color: root.foreground-color;
                                            single-line: true;
                                            input-type: number;
                                            vertical-alignment: center;
                                            text: opt.value-int;
                                            edited => {
                                                // Slint doesn't surface parsed int — pass the text
                                                // through and let Rust validate / clamp.
                                                root.set-option-string(opt.plugin-name, opt.key, self.text);
                                            }
                                            accepted => {
                                                root.set-option-string(opt.plugin-name, opt.key, self.text);
                                                rail-focus.focus();
                                            }
                                            key-pressed(event) => {
                                                if (event.text == Key.Escape) {
                                                    root.close-settings();
                                                    root.show-query();
                                                    return accept;
                                                }
                                                reject
                                            }
                                        }
                                    }

                                    if opt.kind == "enum": Rectangle {
                                        height: 28px;
                                        background: root.muted-color.with-alpha(0.08);
                                        border-radius: 4px;
                                        border-width: 1px;
                                        border-color: root.border-color;
                                        // Minimal "cycle through choices on click" v1 — proper
                                        // dropdowns belong to a later iteration. Choices are
                                        // CSV so we don't need a per-option model.
                                        TouchArea {
                                            clicked => {
                                                root.set-option-string(opt.plugin-name, opt.key, opt.enum-choices);
                                            }
                                            Text {
                                                x: 8px;
                                                text: opt.value-string + "  (click to cycle: " + opt.enum-choices + ")";
                                                color: root.foreground-color;
                                                font-size: root.font-size-subtitle;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }

            // Fallback Escape catcher — every individual focus target
            // (rail, done, hotkey-input, plugin-option inputs) handles Esc
            // itself, but this 0×0 catcher keeps the contract intact in case
            // a future widget forgets to.
            settings-fallback-focus := FocusScope {
                width: 0px;
                height: 0px;
                key-pressed(event) => {
                    if (event.text == Key.Escape) {
                        root.close-settings();
                        root.show-query();
                        return accept;
                    }
                    reject
                }
            }
        }

        // ---- Install-confirmation view ----
        // Shown when `current-view == VIEW-CONFIRM`. Displays plugin metadata,
        // capability list, and Install / Cancel buttons.  Enter confirms;
        // Escape cancels.
        confirm-view := VerticalLayout {
            visible: root.current-view == root.VIEW-CONFIRM;

            // Header bar.
            Rectangle {
                height: 48px;
                background: transparent;
                HorizontalLayout {
                    padding-left: 20px;
                    padding-right: 20px;
                    padding-top: 12px;
                    padding-bottom: 12px;
                    Text {
                        text: "Install Plugin";
                        color: root.foreground-color;
                        font-size: 18px;
                        vertical-alignment: center;
                    }
                }
            }

            Rectangle {
                height: 1px;
                background: root.border-color;
            }

            // Body: scrollable plugin info + capability list.
            ScrollView {
                VerticalLayout {
                    padding: 16px;
                    spacing: 10px;

                    // Plugin name + version.
                    HorizontalLayout {
                        spacing: 8px;
                        alignment: start;
                        Text {
                            text: root.confirm-display-name;
                            color: root.foreground-color;
                            font-size: 16px;
                            vertical-alignment: center;
                        }
                        if root.confirm-version != "": Text {
                            text: "v" + root.confirm-version;
                            color: root.muted-color;
                            font-size: root.font-size-subtitle;
                            vertical-alignment: center;
                        }
                    }

                    // Description.
                    if root.confirm-description != "": Text {
                        text: root.confirm-description;
                        color: root.muted-color;
                        font-size: root.font-size-subtitle;
                        wrap: word-wrap;
                    }

                    // Source URL.
                    Text {
                        text: root.confirm-manifest-url;
                        color: root.muted-color;
                        font-size: root.font-size-subtitle;
                        overflow: elide;
                    }

                    // Capability list header.
                    if root.confirm-capabilities.length > 0: Text {
                        text: "Capabilities requested:";
                        color: root.foreground-color;
                        font-size: root.font-size-title;
                    }

                    // One row per capability.
                    for cap-row in confirm-capabilities: Rectangle {
                        height: 44px;
                        background: cap-row.is-new
                            ? root.highlight-color.with-alpha(0.08)
                            : transparent;
                        border-radius: 4px;
                        HorizontalLayout {
                            padding-left: 8px;
                            padding-right: 8px;
                            padding-top: 4px;
                            padding-bottom: 4px;
                            spacing: 8px;
                            alignment: start;
                            VerticalLayout {
                                alignment: center;
                                // "new" badge for caps that weren't in the
                                // previously installed version.
                                if cap-row.is-new: Text {
                                    text: "+ new";
                                    color: root.highlight-color;
                                    font-size: root.font-size-subtitle;
                                }
                                Text {
                                    text: cap-row.cap;
                                    color: root.foreground-color;
                                    font-size: root.font-size-title;
                                }
                                Text {
                                    text: cap-row.explanation;
                                    color: root.muted-color;
                                    font-size: root.font-size-subtitle;
                                    overflow: elide;
                                }
                            }
                        }
                    }

                    if root.confirm-capabilities.length == 0: Text {
                        text: "This plugin requests no capabilities.";
                        color: root.muted-color;
                        font-size: root.font-size-subtitle;
                    }
                }
            }

            Rectangle {
                height: 1px;
                background: root.border-color;
            }

            // Button row: Install (focused first) and Cancel.
            // A single FocusScope captures keyboard so Enter / Escape
            // work regardless of which button is visually highlighted.
            confirm-focus := FocusScope {
                height: 52px;

                key-pressed(event) => {
                    if (event.text == Key.Return) {
                        if (root.confirm-focus-index == 0) {
                            root.confirm-install();
                        } else {
                            root.confirm-cancel();
                        }
                        return accept;
                    }
                    if (event.text == Key.Escape) {
                        root.confirm-cancel();
                        return accept;
                    }
                    if (event.text == Key.LeftArrow || event.text == Key.UpArrow) {
                        root.confirm-focus-index = 0;
                        return accept;
                    }
                    if (event.text == Key.RightArrow || event.text == Key.DownArrow) {
                        root.confirm-focus-index = 1;
                        return accept;
                    }
                    reject
                }

                HorizontalLayout {
                    padding-left: 16px;
                    padding-right: 16px;
                    padding-top: 10px;
                    padding-bottom: 10px;
                    spacing: 12px;
                    alignment: end;

                    // Cancel button.
                    TouchArea {
                        width: 90px;
                        height: 32px;
                        clicked => {
                            root.confirm-focus-index = 1;
                            root.confirm-cancel();
                        }
                        Rectangle {
                            background: root.confirm-focus-index == 1
                                ? root.muted-color.with-alpha(0.2)
                                : root.muted-color.with-alpha(0.08);
                            border-radius: 6px;
                            border-width: root.confirm-focus-index == 1 ? 1px : 0px;
                            border-color: root.foreground-color;
                            Text {
                                text: "Cancel";
                                color: root.foreground-color;
                                font-size: root.font-size-title;
                                vertical-alignment: center;
                                horizontal-alignment: center;
                            }
                        }
                    }

                    // Install button — receives initial focus.
                    TouchArea {
                        width: 90px;
                        height: 32px;
                        clicked => {
                            root.confirm-focus-index = 0;
                            root.confirm-install();
                        }
                        Rectangle {
                            background: root.confirm-focus-index == 0
                                ? root.highlight-color
                                : root.highlight-color.with-alpha(0.7);
                            border-radius: 6px;
                            border-width: root.confirm-focus-index == 0 ? 1px : 0px;
                            border-color: root.highlight-color;
                            Text {
                                text: "Install";
                                color: white;
                                font-size: root.font-size-title;
                                vertical-alignment: center;
                                horizontal-alignment: center;
                            }
                        }
                    }
                }
            }
        }
    }
}

