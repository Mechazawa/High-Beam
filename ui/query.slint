// Query input + result rows. The single source of truth for what's displayed
// sits on the Rust side; Slint-side state is just `query-text`, `results`,
// and `selected-index`.
//
// Colors and dimensions exposed as `in-out` tokens at the top of `QueryWindow`.
// Defaults match the bundled yosemite-spotlight theme so a theme-free run is
// visually identical to the pre-theming build. Layout-load-bearing constants
// (row height, icon size, input padding) remain inline — theming layout is
// out of scope for v1.

import { ScrollView } from "std-widgets.slint";

// Wire shape sent across Rust -> Slint for each row. `key` is the composite
// `<plugin>:<result_key>` so two plugins emitting the same `key` string don't
// collide. Slint structs need fixed types, so "no icon" is encoded as the
// empty image (`has-icon = false`), and the row paints a muted placeholder
// square in that case to keep title columns aligned.
export struct ResultRow {
    key: string,
    title: string,
    subtitle: string,    // empty string when absent — Slint structs need fixed types
    has-subtitle: bool,
    icon: image,
    has-icon: bool,
}

export component QueryWindow inherits Window {
    title: "High Beam";
    no-frame: true;
    always-on-top: true;
    background: transparent;
    default-font-size: 18px;
    default-font-family: root.font-family;

    in-out property <string> query-text;
    in-out property <[ResultRow]> results: [];
    in-out property <int> selected-index: 0;
    in-out property <int> max-rows: 9;

    // Theme tokens. Defaults reproduce the bundled yosemite-spotlight theme so
    // a missing theme.toml is byte-identical to the pre-theming build.
    in-out property <color> background-color: #ffffffea;
    in-out property <color> foreground-color: #1d1d1f;
    in-out property <color> muted-color: #86868b;
    // `highlight` is part of the documented token surface but not yet bound in
    // markup — kept so user themes can set it without parse errors.
    in-out property <color> highlight-color: #0a84ff;
    in-out property <color> selection-color: #0a84ff33;
    in-out property <color> border-color: #00000010;
    in-out property <string> font-family: "";
    in-out property <length> font-size-query: 32px;
    in-out property <length> font-size-title: 14px;
    in-out property <length> font-size-subtitle: 12px;
    in-out property <length> window-width: 760px;
    in-out property <length> window-border-radius: 14px;

    callback query-edited(string);
    callback escape-pressed();
    // Fires when the user presses Enter on the highlighted row. The Rust side
    // looks up the corresponding result and runs its action.
    callback invoke-selected();

    // forward-focus makes the input the focus target whenever the window
    // itself is focused. Combined with the explicit `input.focus()` call in
    // `focus-input()` (invoked from Rust after each show), this ensures the
    // caret is live the moment the window appears, without needing a click.
    forward-focus: input;

    public function focus-input() {
        input.focus();
    }

    // Reset the input's own `text` directly. The binding `text: root.query-text`
    // is one-way and gets severed the moment the TextInput writes to its own
    // `text` (which happens on every keystroke via the `edited` callback). After
    // that, mutating `query-text` from Rust no longer propagates back into the
    // input. Assigning `input.text` here side-steps the broken binding so the
    // displayed content actually clears.
    public function clear-input() {
        input.text = "";
        root.query-text = "";
        root.results = [];
        root.selected-index = 0;
    }

    // Derived: how tall the rows area should be. Each row is ~52px (padding
    // included). 9 rows max keeps the window from swallowing the whole screen.
    property <int> visible-row-count: min(results.length, max-rows);
    property <length> rows-height: visible-row-count * 56px;
    property <length> input-height: 80px;

    width: root.window-width;
    height: input-height + (results.length > 0 ? rows-height + 1px : 0);

    // Translucent rounded panel sits inside a transparent window so the corner
    // radius reads cleanly on the desktop.
    Rectangle {
        background: root.background-color;
        border-radius: root.window-border-radius;
        border-width: 1px;
        border-color: root.border-color;

        VerticalLayout {
            // Input area
            Rectangle {
                height: input-height;
                input := TextInput {
                    // Span the input area so vertical-alignment has room to
                    // act on. Without an explicit height, the TextInput sizes
                    // to its glyph metrics and the alignment property has
                    // nothing to align against.
                    x: 20px;
                    y: 0;
                    width: parent.width - 40px;
                    height: parent.height;
                    font-size: root.font-size-query;
                    color: root.foreground-color;
                    single-line: true;
                    vertical-alignment: center;
                    text: root.query-text;

                    edited => {
                        root.query-text = self.text;
                        root.query-edited(self.text);
                    }

                    key-pressed(event) => {
                        if (event.text == Key.Escape) {
                            root.escape-pressed();
                            return accept;
                        }
                        if (event.text == Key.Return) {
                            if (root.results.length > 0) {
                                root.invoke-selected();
                            }
                            return accept;
                        }
                        if (event.text == Key.DownArrow) {
                            if (root.selected-index < root.results.length - 1) {
                                root.selected-index += 1;
                            }
                            return accept;
                        }
                        if (event.text == Key.UpArrow) {
                            if (root.selected-index > 0) {
                                root.selected-index -= 1;
                            }
                            return accept;
                        }
                        reject
                    }
                }

                // Faux placeholder: only visible when the input is empty.
                Text {
                    x: 20px;
                    y: 0;
                    width: parent.width - 40px;
                    height: parent.height;
                    text: "Query…";
                    font-size: root.font-size-query;
                    color: root.muted-color;
                    vertical-alignment: center;
                    visible: root.query-text == "";
                }
            }

            // Separator line — only visible when there are results.
            Rectangle {
                height: results.length > 0 ? 1px : 0;
                background: root.border-color;
            }

            // Result rows
            Rectangle {
                height: rows-height;
                clip: true;
                visible: results.length > 0;

                VerticalLayout {
                    spacing: 0px;
                    for row[idx] in results: TouchArea {
                        height: 56px;
                        clicked => {
                            root.selected-index = idx;
                            root.invoke-selected();
                        }
                        Rectangle {
                            background: idx == root.selected-index ? root.selection-color : transparent;
                            HorizontalLayout {
                                padding-left: 20px;
                                padding-right: 20px;
                                padding-top: 8px;
                                padding-bottom: 8px;
                                spacing: 12px;
                                alignment: start;

                                // Icon slot — fixed 36x36 regardless of whether the row has an
                                // icon, so the title column lines up across rows. Image always
                                // paints (defaults to a transparent empty image); the muted
                                // outline behind it is what reads as "no icon" when present.
                                Rectangle {
                                    width: 36px;
                                    height: 36px;
                                    y: (parent.height - self.height) / 2;
                                    border-radius: 4px;
                                    border-width: row.has-icon ? 0px : 1px;
                                    border-color: root.muted-color.with-alpha(0.25);
                                    Image {
                                        x: 0; y: 0;
                                        width: parent.width;
                                        height: parent.height;
                                        source: row.icon;
                                        image-fit: contain;
                                    }
                                }

                                VerticalLayout {
                                    spacing: 2px;
                                    alignment: center;
                                    Text {
                                        text: row.title;
                                        color: root.foreground-color;
                                        font-size: root.font-size-title;
                                        overflow: elide;
                                    }

                                    if row.has-subtitle: Text {
                                        text: row.subtitle;
                                        color: root.muted-color;
                                        font-size: root.font-size-subtitle;
                                        overflow: elide;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
